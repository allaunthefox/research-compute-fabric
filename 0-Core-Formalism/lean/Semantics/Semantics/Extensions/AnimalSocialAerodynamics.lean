import Semantics.FixedPoint
import Semantics.GeneticCode
import Semantics.Spectrum

namespace Semantics.Biology.Social

open Semantics
open Semantics.FixedPoint

/-! ## 1. Ideal Free Distribution (IFD) -/

/-- IFD Input Matching Rule.
    Ni / Σ Nj = Ri / Σ Rj
    The number of individuals in a patch is proportional to the resource renewal rate. -/
def isInputMatched (n_patch n_total r_patch r_total : Q16_16) : Bool :=
  let n_ratio := Q16_16.div n_patch n_total
  let r_ratio := Q16_16.div r_patch r_total
  n_ratio == r_ratio

/-- IFD Fitness Equilibration.
    At equilibrium, individual fitness Fi is equal across all patches. -/
def isFitnessEquilibrated (fitness_list : List Q16_16) : Bool :=
  -- Returns true if all fitness values are equal (within epsilon)
  match fitness_list with
  | [] => true
  | f0 :: fs => fs.all (fun f => f == f0)

/-! ## 2. V-Formation Aerodynamics -/

/-- Vortex Upwash Velocity (v).
    Trailing birds position themselves to capture the positive vertical velocity
    generated by the lead bird's wingtip vortices. -/
def upwashVelocity (circulation distance_to_vortex : Q16_16) : Q16_16 :=
  -- v ∝ Γ / (4π * r)
  let pi4 := Q16_16.mk 0x000C90F1 -- 4π ≈ 12.566 in Q16.16
  Q16_16.div circulation (Q16_16.mul pi4 distance_to_vortex)

/-- Induced Drag Reduction Ratio.
    Formation flight reduces the induced drag Di compared to solo flight. -/
def formationDragReduction (solo_drag num_birds : Q16_16) : Q16_16 :=
  -- Power reduction proxy
  Q16_16.div solo_drag (Q16_16.mul (Q16_16.mk 0x0001B333) num_birds) -- simplified 1.7x boost

/-! ## 3. Collective Efficiency -/

/-- V-Formation Range Extension.
    A formation of birds can increase its flight range by up to 71%. -/
def formationRangeBoost (solo_range : Q16_16) : Q16_16 :=
  -- range' = range * 1.71
  Q16_16.mul solo_range (Q16_16.mk 0x0001B5C2) -- 1.71 in Q16.16

end Semantics.Biology.Social
