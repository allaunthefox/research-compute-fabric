/-- Check if a combination is in the photonic LUT. -/
def inPhotonicLUT (f dh dc eps : Int) : Bool :=
  photonicLUT.any (fun entry =>
    entry.f_raw == f && entry.dh_raw == dh && entry.dc_raw == dc && entry.eps_raw == eps)

/-- Compute the convex combination result for specific values. -/
def computeConvexComb (f_raw dh_raw dc_raw : Int) : Int :=
  let f := Q16_16.ofRawInt f_raw
  let dh := Q16_16.ofRawInt dh_raw
  let dc := Q16_16.ofRawInt dc_raw
  let omf := Q16_16.sub Q16_16.one f
  let term1 := Q16_16.mul f dh
  let term2 := Q16_16.mul omf dc
  let result := Q16_16.add term1 term2
  (Q16_16.abs result).toInt

