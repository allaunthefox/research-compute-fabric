/-- Decision procedure: check if a combination satisfies the bound. -/
def checkBound (f dh dc eps : Int) : Bool :=
  if Int.natAbs dh ≤ Int.natAbs eps ∧ Int.natAbs dc ≤ Int.natAbs eps then
    -- ACI hypothesis holds, check if in LUT
    inPhotonicLUT f dh dc eps
  else
    -- ACI hypothesis doesn't hold, bound may not hold
    false

/-- The decision procedure is sound: if it returns true, the bound holds. -/
theorem decision_procedure_sound (f dh dc eps : Int)
    (h_decision : checkBound f dh dc eps = true) :
    let f_val := Q16_16.ofRawInt f
    let dh_val := Q16_16.ofRawInt dh
    let dc_val := Q16_16.ofRawInt dc
    let eps_val := Q16_16.ofRawInt eps
    let omf_val := Q16_16.sub Q16_16.one f_val
    let term1_val := Q16_16.mul f_val dh_val
    let term2_val := Q16_16.mul omf_val dc_val
    let result_val := Q16_16.add term1_val term2_val
    let abs_result_val := Q16_16.abs result_val
    abs_result_val.toInt ≤ eps_val.toInt := by
