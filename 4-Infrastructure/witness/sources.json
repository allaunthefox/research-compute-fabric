      },
      "url": "shared-data/artifacts/science_toolbelt/probe.json",
      "schema": "research_stack_optional_science_toolbelt_probe_v1",
      "hook_kind": "post-event-script",
      "visibility": "internal",
      "cost_policy": {
        "trusted_actors": [],
        "trusted": 1.0,
        "untrusted": 1.0,
        "public": 1.0
      }
    },
    "deepseek-review": {
      "active": true,
      "backend": {
        "type": "toolbelt",
