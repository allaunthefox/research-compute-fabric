    date-published: 2015
    doi: "10.1109/ITW.2015.7133169"
    url: "https://arxiv.org/abs/1503.02406"
    notes: "Information bottleneck principle applied to deep neural networks. Referenced in framework documentation."

  - type: article
    title: "Algorithmic Information Theory"
    authors:
      - family-names: "Grunwald"
        given-names: "Peter D."
      - family-names: "Vitanyi"
        given-names: "Paul M. B."
    booktitle: "Philosophy of Information"
    publisher: "Elsevier North-Holland"
    pages: "281-317"
    date-published: 2008
    doi: "10.1016/B978-0-444-51726-5.50013-3"
    url: "https://doi.org/10.1016/B978-0-444-51726-5.50013-3"
    notes: "Comprehensive tutorial on Kolmogorov complexity and algorithmic information theory."

